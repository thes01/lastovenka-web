---
import siteConfig from '../data/site-config';
// todo: remove when tailwind is set up globally
import '../styles/global.css';

const hero = siteConfig.hero;
---

{
    hero?.image && (
        <figure class="fixed top-0 left-0 w-screen h-screen flex justify-center">
            <img class="flex object-contain" src={hero.image.src} loading="lazy" decoding="async" alt={hero.image.alt || ''} />
        </figure>
    )
}
